# Supabase authentication and database
# Find these in Supabase: Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Required only for server-only admin operations, including initial admin creation.
# Never expose this in browser/client code.
ADMIN_SETUP_SECRET=your_admin_secret_here

# OpenAI (used for AI document builder and shift notes)
OPENAI_API_KEY=your_openai_api_key

# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# Stripe Price IDs — create recurring prices in Stripe Dashboard > Products
# Each should be a monthly recurring price in AUD
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# App URL (used for Stripe redirects and OAuth callbacks)
NEXT_PUBLIC_APP_URL=https://sataus.net
