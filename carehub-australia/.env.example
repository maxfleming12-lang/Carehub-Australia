# Supabase authentication and database
# Find these in Supabase: Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Required only for server-only admin operations, including initial admin creation.
# Never expose this in browser/client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required only while using POST /api/admin/create-admin.
# Generate with: openssl rand -hex 32
ADMIN_SETUP_SECRET=replace-with-a-random-secret

# Optional integrations
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
